#: ../src/actionhandlers.c:823
#, c-format
msgid "Copy of %s"
msgstr "%s көшірмесі"

#: ../src/actionhandlers.c:826
#, c-format
msgid "Copy of %s (%d)"
msgstr "%s көшірмесі (%d)"

#: ../src/main.c:139
#, c-format
msgid "Usage: deadbeef [options] [--] [file(s)]\n"
msgstr "Қолданылуы: deadbeef [опциялар] [файл(дар)]\n"

#: ../src/main.c:140
#, c-format
msgid "Options:\n"
msgstr "Опциялары:\n"

#: ../src/main.c:141
#, c-format
msgid "   --help  or  -h     Print help (this message) and exit\n"
msgstr "   --help  не  -h     Көмек ақпаратын (осы) шығару мен шығу\n"

#: ../src/main.c:142
#, c-format
msgid "   --quit             Quit player\n"
msgstr "   --quit             Плеерді жабу\n"

#: ../src/main.c:143
#, c-format
msgid "   --version          Print version info and exit\n"
msgstr "   --version          Нұсқа ақпаратын шығару мен шығу\n"

#: ../src/main.c:144
#, c-format
msgid "   --play             Start playback\n"
msgstr "   --play             Ойнатуды бастау\n"

#: ../src/main.c:145
#, c-format
msgid "   --stop             Stop playback\n"
msgstr "   --stop             Ойнатуды тоқтату\n"

#: ../src/main.c:146
#, c-format
msgid "   --pause            Pause playback\n"
msgstr "   --pause            Ойнатуды аялдату\n"

#: ../src/main.c:147
#, c-format
msgid "   --toggle-pause     Toggle pause\n"
msgstr "   --toggle-pause     Паузаны ауыстыру\n"

#: ../src/main.c:148
#, c-format
msgid ""
"   --play-pause       Start playback if stopped, toggle pause otherwise\n"
msgstr "   --play-pause       Тоқтатылған болса, ойнату, болмаса, паузаны ауыстыру\n"

#: ../src/main.c:149
#, c-format
msgid "   --next             Next song in playlist\n"
msgstr "   --next             Ойнату тізіміндегі келесі трек\n"

#: ../src/main.c:150
#, c-format
msgid "   --prev             Previous song in playlist\n"
msgstr "   --prev             Ойнату тізіміндегі алдыңғы трек\n"

#: ../src/main.c:151
#, c-format
msgid "   --random           Random song in playlist\n"
msgstr "   --random           Ойнату тізіміндегі кездейсоқ трек\n"

#: ../src/main.c:152
#, c-format
msgid "   --queue            Append file(s) to existing playlist\n"
msgstr "   --queue            Файл(дар)ды бар ойнату тізіміне қосу\n"

#: ../src/main.c:153
#, c-format
msgid "   --gui PLUGIN       Tells which GUI plugin to use, default is \"GTK3\"\n"
msgstr "   --gui PLUGIN       Қай GUI плагині қолданылатынын айтады, бастапқысы — «GTK3»\n"

#: ../src/main.c:154
#, c-format
msgid "   --nowplaying FMT   Print formatted track name to stdout\n"
msgstr "   --nowplaying ПШМ   Шығысқа пішімделген трек атын шығару\n"

#: ../src/main.c:157
#, c-format
msgid ""
"                      FMT %%-syntax: [a]rtist, [t]itle, al[b]um,\n"
"                      [l]ength, track[n]umber, [y]ear, [c]omment,\n"
"                      copy[r]ight, [e]lapsed\n"
msgstr "                      Пішімі %% синтаксисі: [a]rtist, [t]itle, al[b]um,\n                      [l]ength, track[n]umber, [y]ear, [c]omment,\n                      copy[r]ight, [e]lapsed\n"

#: ../src/main.c:160
#, c-format
msgid ""
"                      example: --nowplaying \"%%a - %%t\" should print "
"\"artist - title\"\n"
msgstr "                      мысалы: --nowplaying \"%%a - %%t\" келесідей шығаруы керек: \"орындаушы - атауы\"\n"

#: ../src/main.c:163
#, c-format
msgid "                      for more info, see %s\n"
msgstr "                      көбірек білу үшін, %s қараңыз\n"

#: ../src/main.c:165
#, c-format
msgid "                      NOTE: --nowplaying is deprecated.\n"
msgstr "                      ЕСКЕРТПЕ: --nowplaying ескірген.\n"

#: ../src/main.c:168
#, c-format
msgid ""
"   --nowplaying-tf FMT  Print formatted track name to stdout, using the new "
"title formatting\n"
msgstr "   --nowplaying-tf FMT  Жаңа атау пішімін қолданып, пішімделген трек атын stdout-қа шығару\n"

#: ../src/main.c:171
#, c-format
msgid ""
"                      FMT syntax: http://github.com/DeaDBeeF-"
"Player/deadbeef/wiki/Title-formatting-2.0\n"
msgstr "                      FMT синтаксисі: http://github.com/DeaDBeeF-Player/deadbeef/wiki/Title-formatting-2.0\n"

#: ../src/main.c:174
#, c-format
msgid ""
"                      example: --nowplaying-tf \"%%artist%% - %%title%%\" "
"should print \"artist - title\"\n"
msgstr "                      мысалы: --nowplaying-tf \"%%artist%% - %%title%%\" келесідей шығаруы керек: \"орындаушы - атауы\"\n"

#: ../src/main.c:175
#, c-format
msgid "   --volume [NUM]     Print or set deadbeef volume level.\n"
msgstr "   --volume [NUM]     DeaDBeeF дыбыс деңгейін шығару немесе орнату.\n"

#: ../src/main.c:178
#, c-format
msgid ""
"                      The NUM parameter can be specified in percents "
"(absolute value or increment/decrement)\n"
msgstr "                      NUM параметрі пайызбен көрсетілуі мүмкін (абсолютті мән немесе өсім/кему)\n"

#: ../src/main.c:179
#, c-format
msgid "                      or in dB [-50, 0] (if with suffix).\n"
msgstr "                      немесе дБ түрінде [-50, 0] (суффикспен болса).\n"

#: ../src/main.c:180
#, c-format
msgid ""
"                      Examples: --volume 80, --volume +10, --volume -5 or "
"--volume -20dB\n"
msgstr "                      Мысалдар: --volume 80, --volume +10, --volume -5 немесе --volume -20dB\n"

#: ../src/main.c:183
#, c-format
msgid ""
"   --plugin=[PLUG]    Send commands to a specific plugin. Use PLUG=main to "
"send commands to deadbeef itself.\n"
msgstr "   --plugin=[PLUG]    Белгілі бір плагинге командалар жіберу. DeaDBeeF-тің өзіне команда жіберу үшін PLUG=main қолданыңыз.\n"

#: ../src/main.c:184
#, c-format
msgid ""
"                      To get plugin specific commands use --plugin=[PLUG] "
"--help\n"
msgstr "                      Плагинге тән командаларды алу үшін --plugin=[PLUG] --help қолданыңыз\n"

#: ../src/main.c:187
#, c-format
msgid ""
"   --plugin-list      List all available plugins including indication for "
"plugins that support commands.\n"
msgstr "   --plugin-list      Қолжетімді барлық плагиндерді, соның ішінде командаларды қолдайтындарын көрсету.\n"

